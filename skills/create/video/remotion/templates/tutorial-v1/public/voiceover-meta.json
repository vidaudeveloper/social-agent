  "beats": [
    {"id": "o1", "text": "多账号运营时，为什么总是莫名其妙被风控？", "startSec": 0, "endSec": 2.0, "durationSec": 2.0},
    {"id": "o2", "text": "先别急着重装软件，问题往往出在环境隔离。", "startSec": 2.0, "endSec": 4.0, "durationSec": 2.0},
    {"id": "r1", "text": "风控通常同时看设备指纹、网络出口和登录行为。", "startSec": 4.0, "endSec": 5.8, "durationSec": 1.8},
    {"id": "c1", "text": "错误做法是共用一台裸机；推荐做法是隔离环境加独立出口。", "startSec": 5.8, "endSec": 7.8, "durationSec": 2.0},
    {"id": "d1", "text": "CloudDesk 提供三块能力：环境、代理、批量管理。", "startSec": 7.8, "endSec": 9.6, "durationSec": 1.8},
    {"id": "d2", "text": "第一步：打开控制台，新建一个独立环境。", "startSec": 9.6, "endSec": 11.2, "durationSec": 1.6},
    {"id": "d3", "text": "看真实界面：在控制台点击新建，并填写环境名称。", "startSec": 11.2, "endSec": 13.0, "durationSec": 1.8},
    {"id": "d4", "text": "第二步：在设置里绑定出口节点，并保存。", "startSec": 13.0, "endSec": 14.6, "durationSec": 1.6},
    {"id": "s1", "text": "一套底座锁风格，换旁白和截图就能做新教程。", "startSec": 14.6, "endSec": 16.4, "durationSec": 1.8},
    {"id": "s2", "text": "现在就用模板脚手架开始你的下一支教程片。", "startSec": 16.4, "endSec": 18.0, "durationSec": 1.6}
  ]
}
