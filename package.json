{
  "name": "social-agent",
  "version": "1.0.0",
  "private": true,
  "description": "社媒运营老兵 VidAU profile — 海外/Reddit 工具安装与 CLI 包装",
  "type": "module",
  "scripts": {
    "tool:install": "node scripts/run-tool-install.mjs",
    "pipeline:xhs": "node scripts/pipeline-xhs.mjs",
    "xhs:card-render": "node scripts/run-xhs-card.mjs",
    "overseas:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-overseas-tools.ps1",
    "reddit:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-reddit-tools.ps1",
    "reddit:check-login": "node skills/social-media/reddit/scripts/cli.mjs login",
    "reddit:feed": "node skills/social-media/reddit/scripts/cli.mjs feed",
    "reddit:validate": "node skills/social-media/reddit/scripts/cli.mjs validate-publish",
    "reddit:publish": "node skills/social-media/reddit/scripts/cli.mjs publish",
    "tiktok:login": "node scripts/run-tiktok.mjs login --account default",
    "tiktok:check-login": "node scripts/run-tiktok.mjs check-login --account default",
    "tiktok:open-drafts": "node scripts/run-tiktok.mjs open-drafts --account default",
    "tiktok:publish": "node scripts/run-tiktok.mjs publish",
    "tiktok:create-video": "node skills/social-media/tiktok/scripts/cli.mjs create-video",
    "tiktok:voices": "node skills/social-media/tiktok/scripts/cli.mjs list-voices",
    "pipeline:tiktok": "node skills/social-media/tiktok/scripts/cli.mjs create-video",
    "linkedin:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-linkedin-tools.ps1",
    "linkedin:login": "node scripts/run-linkedin.mjs login",
    "linkedin:check-login": "node scripts/run-linkedin.mjs check-login",
    "linkedin:publish": "node scripts/run-linkedin.mjs publish",
    "linkedin:stats": "node scripts/run-linkedin.mjs stats",
    "x:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-baoyu-x-tools.ps1",
    "x:login": "node scripts/run-x.mjs login",
    "x:check-login": "node scripts/run-x.mjs check-login",
    "x:preflight": "node scripts/run-x.mjs preflight",
    "x:publish": "node scripts/run-x.mjs publish",
    "review:lint": "node skills/content-reviewer/scripts/lint.mjs",
    "review:sync-specs": "node skills/content-reviewer/scripts/sync-publish-specs.mjs"
  }
}
