# Environment variables required by this Hermes distribution.
# Copy to `.env` in the same directory and fill in your own values before running.

# =============================================================================
# Required
# =============================================================================

# Tokenware AI API Key (用于模型推理 + 配图生成)
# 获取: https://www.tokenware.ai
TOKENWARE_API_KEY=

# =============================================================================
# Optional — 平台发布凭据
# =============================================================================

# 微信公众平台 AppID / AppSecret（公众号发布需要）
# 获取: mp.weixin.qq.cn → 开发 → 基本配置
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# Tavily API Key（可选，用于热点搜索增强）
# TAVILY_API_KEY=

# YouTube Data API v3（explore TubePilot + analytics/youtube 公开数据可共用）
# get_transcript 与 youtube-transcript-api 不需要
# 申请步骤见 workspace/references/youtube-explore-setup.md
# YOUTUBE_API_KEY=

# YouTube Analytics 报表（analytics/youtube 的 report / 无 ID channels；OAuth Desktop）
# 启用 YouTube Analytics API；scopes 见 skills/analytics/youtube/references/setup.md
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=

# =============================================================================
# Optional — Remotion / ElevenLabs 配音
# =============================================================================

# ElevenLabs API Key（知识分享片旁白；不设则回退 edge-tts）
# 获取: https://elevenlabs.io → Profile → API Key
# ELEVENLABS_API_KEY=

# 可选：音色 / 模型（中文讲述建议 speed≥1.1，避免偏慢）
# ELEVENLABS_VOICE_ID=WkcRFJo38X9XEP8kGExm
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_STABILITY=0.45
# ELEVENLABS_SIMILARITY=0.75
# ELEVENLABS_STYLE=0.2
# ELEVENLABS_SPEED=1.5
# VOICEOVER_GAP_SEC=0.15
# 说明：API 语速上限 1.2；>1.2 时脚本会用 ffmpeg atempo 补到目标语速
